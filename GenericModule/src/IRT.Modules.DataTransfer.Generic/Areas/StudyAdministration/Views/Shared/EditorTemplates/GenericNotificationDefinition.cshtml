@using Kendo.Mvc.UI
@using Kernel.AspNetMvc.Utilities
@using Kernel.Utilities.Extensions
@model IRT.Modules.DataTransfer.Generic.Areas.StudyAdministration.Models.GenericNotificationDefinitionViewModel

<script type="text/javascript">
    function onSelect(e) {
        kendo.ui.progress($('.custom-layout-popup-form'), true);
        var file = e.files[0];
        $('\\#FileName').val(file.name).trigger('change');
        $('\\#MimeType').val(file.rawFile.type).trigger('change');
        var reader = new FileReader();
        reader.readAsArrayBuffer(e.files[0].rawFile);
        reader.onload = function () {
            var arrayBuffer = this.result;
            var array = new Uint8Array(arrayBuffer);
            var bufferLength = array.length;
            var base64String = '';
            for (var i = 0; i < bufferLength; i++) {
                base64String += String.fromCharCode(array[i]);
            }
            var base64 = btoa(base64String);
            $('\\#FileContent').val(base64).trigger('change');
            $('.k-upload-files').addClass('k-file-success');
            kendo.ui.progress($('.custom-layout-popup-form'), false);
        }
    }
</script>
<div id="section-edit-form" class="custom-layout-popup-form">
    <div class="form-group">
        <div class="editor-label ic-editor-label">
            @Html.LabelFor(model => model.Name, new { @class = "required" })
        </div>
        <div class="editor-field ic-editor-field">
            @Html.EditorFor(x => x.Name)
            @Html.ValidationMessageFor(x => x.Name)
        </div>
    </div>

    <div class="form-group">
        <div class="editor-label ic-editor-label">
            @Html.LabelFor(model => model.ApacheHopResourceEndpoint, new { @class = "required" })
        </div>
        <div class="editor-field ic-editor-field">
            @Html.EditorFor(x => x.ApacheHopResourceEndpoint)
            @Html.ValidationMessageFor(x => x.ApacheHopResourceEndpoint)
        </div>
    </div>

    <div class="form-group" id="HtmlEditor-Title">
        <div class="editor-label ic-editor-label">
            @Html.LabelFor(model => model.Title, new { @class = "required" })
        </div>
        <div id="markdown-editor" class="editor-field ic-editor-field">
            @Html.TextAreaFor(x => x.Title, new { style = "display:none" })
            @Html.ValidationMessageFor(model => model.Title)
        </div>
    </div>

    <div class="form-group" id="HtmlEditor-Body">
        <div class="editor-label ic-editor-label">
            @Html.LabelFor(model => model.Body, new { @class = "required" })
        </div>
        <div id="markdown-editor" class="editor-field ic-editor-field">
            @Html.TextAreaFor(x => x.Body, new { style = "display:none" })
            @Html.ValidationMessageFor(model => model.Body)
        </div>
    </div>

    <div class="form-group">
        <div class="editor-label ic-editor-label">
            @Html.LabelFor(model => model.NotificationVendor, new { @class = "required" })
        </div>
        <div class="editor-field ic-editor-field">
            @(Html.Kendo().DropDownListFor(x => x.NotificationVendor)
                .HtmlAttributes(new { style = "width:100%" })
                .DataTextField("Text")
                .DataValueField("Value")
                .OptionLabel("< Select >")
                .BindTo((IEnumerable<SelectListItem>)ViewBag.NotificationVendor))
            @Html.ValidationMessageFor(x => x.NotificationVendor)
        </div>
    </div>
    <div class="form-group">
        <div class="editor-label ic-editor-label">
            @Html.LabelFor(model => model.NotificationType, new { @class = "required" })
        </div>
        <div class="editor-field ic-editor-field">
            @(Html.Kendo().DropDownListFor(x => x.NotificationType)
                .HtmlAttributes(new { style = "width:100%" })
                .DataTextField("Text")
                .DataValueField("Value")
                .OptionLabel("< Select >")
                .BindTo((IEnumerable<SelectListItem>)ViewBag.NotificationType))
            @Html.ValidationMessageFor(x => x.NotificationType)
        </div>
    </div>
</div>
<br />

<style type="text/css">
    .ic-editor-label {
        width: 16% !important;
    }

    .ic-editor-field {
        float: left !important;
        margin-left: 20px !important;
    }

    .k-edit-form-unityContainer .k-text-value {
        width: 300px !important;
    }

    .k-edit-form-unityContainer .k-numerictextbox {
        width: 100px !important;
    }

    .k-edit-form-unityContainer .k-editor-toolbar-wrap {
        width: 800px !important;
    }

    .k-editor-toolbar {
        display: flex;
        flex-wrap: wrap;
        overflow: hidden;
        justify-content: flex-start;
    }

    .k-button.k-tool {
        padding: 0;
        color: gray;
    }

    .k-picker-wrap {
        margin-left: 5px;
        border-color: lightgrey;
    }
</style>