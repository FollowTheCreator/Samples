[EnableQuery(@enableQuerySettings)]
//Please use this attribute allow Kernel.OData module to determine how the endpoint should look like
@suppressOldRoutes [Route("@(idParams)")]
@suppressNewRoutes [Route("@(newRoute)/@(idParams)")]
@suppressNewRoutes [SwaggerOperation(Tags = new[] { "@(newRealm)" })]
[Produces(typeof(@tableType))]
public ActionResult Get
(
