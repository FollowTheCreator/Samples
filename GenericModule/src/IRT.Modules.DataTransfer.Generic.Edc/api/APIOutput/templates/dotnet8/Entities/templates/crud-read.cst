%%
string tableType = entityTableType.Replace("_",".");
string tableName = $"Set<{@tableType}>()";

bool useNewRoutes = Entity.Features["UseNewRoutes"].Values[0].ToString() == "True";
string suppressOldRoutes = useNewRoutes ? "// old routes --" : ""; 
string suppressNewRoutes = useNewRoutes ? "" : "// new routes --";
string newRoute = Entity.Features["Route"].Values[0].ToString();
string newRealm = Entity.Features["Route"].Values[1].ToString() + " : EntityReads : " + Entity.Features["Route"].Values[2].ToString();
string enableQuerySettings = Entity.Features["EnableQuerySettings"].Values.First().ToString();

%%
//Use this to allow Kernel.OData module to determine what methods to register as odata masked endpoints
//One can also use the "Get" as method name
[HttpGet]
//Use this attribute to enable standard odata support for a given method
[EnableQuery(@enableQuerySettings)]
//Please use this attribute allow Kernel.OData module to determine how the endpoint should look like
@suppressNewRoutes [Route("@(newRoute)")]
@suppressNewRoutes [SwaggerOperation(Tags = new[] { "@(newRealm)" })]
[Produces(typeof(IQueryable<@tableType>))]
public ActionResult Get()
{
    ActionResult response;

    try
    {
        IQueryable<@tableType> result
            = DbContext.@(tableName).AsQueryable();

        response = Ok(result);
    }
    catch (Exception e)
    {
        response = Error(e);
    }

    return response;
}
%%
string comma;
string idParams = default;
string slash = default;
foreach (string name in primaryKeyList.Keys)
{
    %>/// <param name="@(name)">@(name)</param>
idParams += $"{slash}{{{name}}}";
slash = "/";
}
%%
