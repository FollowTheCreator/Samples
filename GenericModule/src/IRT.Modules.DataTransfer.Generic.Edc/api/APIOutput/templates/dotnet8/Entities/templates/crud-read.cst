%%
comma = "  ";
string typeName;
foreach (string name in primaryKeyList.Keys)
{
typeName = primaryKeyList[name].Replace("_",".").Replace("__","_");
if (typeName.StartsWith("optional_"))
{
    typeName = typeName.Substring(9);
    if (typeName.Equals("guid"))
    {
        typeName = "Guid";
    }
    typeName = typeName+"?";
}
    %>@(comma)@(typeName) @(name)
    comma = ", ";
}
%%
