%%
bool IsImmutable = false;
bool IsEF = true;

bool useNewRoutes = Entity.Features["UseNewRoutes"].Values[0].ToString() == "True";
string suppressOldRoutes = useNewRoutes ? "// old routes --" : ""; 
string suppressNewRoutes = useNewRoutes ? "" : "// new routes --"; 

// Precalculate how many validations this entity uses, since we'll need that
// answer in a few places.  If you change `validation.cst`, be sure to change
// this logic as well to match it.
int NumValidations = 0;
foreach (PropertyInfo p in Entity.Properties) {
    if (p.Kind == PropertyKind.Alias)
        continue;

    if (p.Type == PropertyType.Reference) {
        if (IsImmutable && !p.IsOptional)
            NumValidations++;
    }
    else if (p.Type == PropertyType.ReferenceCollection) {
        if (IsImmutable && !p.IsOptional)
            NumValidations += 2;
    }
    else if (p.Type == PropertyType.String || p.Type == PropertyType.Json) {
        if (p.CombinedConstraints.Length.HasValue)
            NumValidations++;
        else {
            if (p.CombinedConstraints.MinLength.HasValue)
                NumValidations++;
            if (p.CombinedConstraints.MaxLength.HasValue)
                NumValidations++;
        }
        if (p.CombinedConstraints.Matches != null && p.CombinedConstraints.Matches.Any())
            NumValidations += p.CombinedConstraints.Matches.Count;
    }
}

bool HasEntityReadRule = Entity.AuthReadRule.IsMeaningful();
bool HasEntityWriteRule = Entity.AuthWriteRule.IsMeaningful();
bool HasPropertyReadRules = Entity.Properties.Any(p => p.AuthReadRule.IsMeaningful());

// This is a collection of all of the interfaces to be added to the entity.
// We only add interfaces where required, and this is a HashSet to avoid duplication.
HashSet<string> EntityInterfaces = new HashSet<string>();
EntityInterfaces.Add("System.IEquatable<" + Entity.ShapeName + ">");
if (HasEntityReadRule || HasPropertyReadRules)
    EntityInterfaces.Add("IReadAuthorizedEntity");
if (HasEntityWriteRule)
    EntityInterfaces.Add("IWriteAuthorizedEntity");
if (HasEntityWriteRule || NumValidations > 0)
    EntityInterfaces.Add("ISaveTrackedEntity");
if (Entity.IsRoot)
    EntityInterfaces.Add("IAggregateRoot");

if (Entity.Exposure == ExposureKind.Protected
    || Entity.Exposure == ExposureKind.Private
    || Entity.Exposure == ExposureKind.Internal)
    Error(Entity.Location, $"Entity '{Entity.FullName}' cannot be declared '{Entity.Exposure.Value.ToString().ToLower()}'.");
%%
%include "_header.cst"

%%
string pkMessage = default;
string pkValue = default;
int dot;

string route = Entity.Features["Realm"].Values[0].ToString();
string layer = Entity.Features["Realm"].Values[1].ToString();
string realm = string.Join(" > ", Entity.Features["Realm"].Values);

if (Entity.Features.ContainsKey("Subfolder"))
{
    route += $"/{Entity.Features["Subfolder"].Values[0].ToString()}";
}

string entityShapeName = Entity.ShapeName;
string entityTableType = Entity.Features["DbContextTableType"].Values.First().ToString();
string tableType = entityTableType.Replace("_",".");
string entityTableName = Entity.Features["DbContextTableName"].Values.First().ToString();
string tableName = $"Set<{@tableType}>()";
string prefix;
if (layer.Equals("EntityReads"))
{
    prefix = "";
}
else
{
    prefix = "";
}
%%

namespace @Entity.ShapeNamespace.Replace(".Shapes",default)
{
%include "documentation.cst"
%Indent += 4;
%WriteXmlDocumentation(Entity?.Documentation, "The standard controller for a " + Entity.ShapeName + " entity.");
%Indent -= 4;
    @suppressOldRoutes [Realm("@realm")]
    @suppressOldRoutes [Route("@(prefix)IRT/v1/@(route)/@(entityShapeName)")]
    [Produces("application/json")]
    public class @(entityShapeName)@(layer)Controller : @(layer)Controller
    {
#region Constructors

        /// <summary>
        /// constructor
        /// </summary>
        public @(entityShapeName)@(layer)Controller
        (
            IHttpContextAccessor httpContextAccessor,
            IUnityContainer unityContainer,
            IRTDbContext dbContext
        )
        : base(httpContextAccessor, unityContainer, dbContext)
        {
        }

#endregion
%%
string primaryKeyType = default;
string primaryKeyName = default;

string pName = default;

Dictionary<string, string> primaryKeyList = new Dictionary<string, string>();
Dictionary<string, string> primaryKeyRefList = new Dictionary<string, string>();

// find the primary key names
foreach (PropertyInfo p in Entity.Properties) {

    if (Entity.Features["PrimaryKey"].Values.Contains(p.Name))
    {
        if (p.Name.Equals($"{entityShapeName}X"))
        {
            primaryKeyName = entityShapeName;
        }
        else
        {
            primaryKeyName = p.Name;
        }

        primaryKeyType = p.CSharpTypeName;
        int suffix = primaryKeyType.LastIndexOf(".");
        if (-1 < suffix)
        {
            primaryKeyType = primaryKeyType.Substring(suffix+1);
        }

        primaryKeyList[primaryKeyName] = primaryKeyType;
        primaryKeyRefList[primaryKeyName] = primaryKeyName;
    }
}
if (primaryKeyList.Keys.Count < 1)
{
    throw(new Exception(@$"NO Primary Key found for {Entity.ShapeName}"));
}
%%
%Indent += 4;
%Indent += 4;

%dot = tableType.LastIndexOf('.');
%string tablename = (dot < 0 ? tableType : tableType.Substring(dot + 1));

public static void RegisterModel(ODataModelBuilder builder)
{
%%
Indent += 4;
if (1 < primaryKeyList.Keys.Count)
{
string keyList = "";
comma = "{";
foreach (string name in primaryKeyList.Keys)
{
    keyList = keyList+comma+"e."+name;
    comma = ", ";
}
keyList = keyList+"}";
%>builder.EntityType<@tableType>().HasKey(e => new @(keyList));
}
%%
builder.EntitySet<@tableType>("@tablename");
%Indent -= 4;
}
