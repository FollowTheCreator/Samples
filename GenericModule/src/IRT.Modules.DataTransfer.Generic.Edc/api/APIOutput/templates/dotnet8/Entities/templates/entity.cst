    /// <summary>
    /// input schema for the entity
    /// </summary>
    public class @(entityShapeName)Input
    {
%Indent += 4;
%Indent += 4;
%Indent += 4;
%Indent += 4;
%%
            bool isFirst = true;
            string comma = "  ";
            foreach (PropertyInfo p in Entity.Properties) {
                if(
                    (p.Type != PropertyType.Reference)
                &&  (p.CSharpTypeName.StartsWith("Collection") == false)
                &&  (p.CSharpTypeName.StartsWith("ICollection") == false)
                &&  (p.CSharpTypeName.StartsWith("IList") == false)
                &&(
                    (p.IsWrappedType == false)
                ||
                    (primaryKeyList.Keys.Contains(p.Name) == false)
                )
                &&  (p.Features.Keys.Contains("readonly") == false)
                ){
                    pName = p.Name;

                    if(pName.Equals($"{entityShapeName}X"))
                    {
                        pName = pName.Substring(0, pName.Length-1);
                    }

                    string cName = @p.CSharpTypeName.Replace("_",".").Replace("__","_");

                    cName = cName.Replace("_Array","[]");
                    dot = cName.LastIndexOf(".AAA.");
                    if (-1 < dot)
                    {
                        cName = cName.Substring(dot+1);
                    }
                    dot = cName.LastIndexOf('.');
                    string typeName = (dot < 0 ? cName : cName.Substring(dot + 1));
                    if (typeName.StartsWith("optional_"))
                    {
                        typeName = typeName.Substring(9);
                        if (typeName.Equals("guid"))
                        {
                            typeName = "Guid";
                        }
                        typeName = typeName+"?";
                    }
                    else if (typeName.Equals("MailPriority"))
                    {
                        dot = -1;
                    }
                    if (-1 < dot)
                    {
                        typeName = cName.Substring(0, dot+1) + typeName;
                    }
                    if (isFirst != true) %>
                    isFirst = false;
                    %>/// <summary>
                    %>/// @pName
                    %>/// </summary>
                    %>public @typeName @(pName) {get; set;}
                }
                else
                {
                    if (isFirst != true) %>
                    isFirst = false;
                    %>// @p.CSharpTypeName @p.Name --> @p.Type IsWrappedType=@p.IsWrappedType isPrimaryKey=@primaryKeyList.Keys.Contains(p.Name)
                }
            }
%%
%Indent -= 4;
%Indent -= 4;
%Indent -= 4;
%Indent -= 4;
    }
%Indent -= 4;
